# -------------------------------------------------------
# Agent Core Infrastructure — Environment Variables
# -------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# All variables are optional — sensible defaults are used.
#
# NOTE: Business-specific settings (GitLab tokens, project IDs, etc.)
# should be managed per-project by the upper business layer, NOT here.

# --- Anthropic / Claude SDK ---
ANTHROPIC_API_KEY=sk-xxx
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=16384
ANTHROPIC_MAX_TURNS=50
ANTHROPIC_PERMISSION_MODE=bypassPermissions
ANTHROPIC_TIMEOUT_SECONDS=300

# --- Sandbox / Workspace ---
SANDBOX_ENABLED=false
SANDBOX_WORKSPACE_ROOT=/tmp/agent_workspaces
SANDBOX_NETWORK_ALLOWED_HOSTS=[]
SANDBOX_MAX_FILE_SIZE_MB=50

# --- Platform ---
PLATFORM_DEBUG=false
PLATFORM_LOG_LEVEL=INFO
PLATFORM_MAX_CONCURRENT_AGENTS=5
